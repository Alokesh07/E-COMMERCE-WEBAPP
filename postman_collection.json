    {
      "name": "Admin Access Tests",
      "item": [
        {
          "name": "Access admin route without token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/protected",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "protected"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('401 or 403 without token', function () { pm.expect(pm.response.code).to.be.oneOf([401,403]); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Access admin route with non-admin token",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/protected",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "protected"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('403 for non-admin', function () { pm.expect(pm.response.code).to.be.oneOf([403]); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
